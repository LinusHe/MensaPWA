rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user access for notification users
    match /notificationUsers/{userId} {
      // allow unauthenticated writes if the payload's userId matches the doc id.
      allow read: if true;
      allow write: if (
        (request.auth != null && request.auth.uid == userId) ||
        (
          request.auth == null &&
          request.resource != null &&
          request.resource.data.userId == userId &&
          // Restrict which fields can be set without auth
          request.resource.data.keys().hasOnly([
            'enabled', 'userId', 'fcm_token', 'nextNotification', 'preferences'
          ]) &&
          request.resource.data.preferences.keys().hasOnly(['days', 'time', 'timezone'])
        )
      );
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Server-only image cache (no client access)
    match /imagesCache/{cacheKey} {
      allow read, write: if false;
    }
  }
}